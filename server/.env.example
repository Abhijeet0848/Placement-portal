# Server Configuration
PORT=5000
NODE_ENV=production
CLIENT_ORIGIN=https://your-smart-placement-portal.vercel.app

# Database Configuration (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_placement?retryWrites=true&w=majority

# JWT Authentication Secrets
JWT_SECRET=super_secret_jwt_access_token_key_change_in_production
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=super_secret_refresh_token_key_change_in_production
REFRESH_TOKEN_EXPIRES_IN=7d

# Gemini AI Key (Google Generative AI)
GEMINI_API_KEY=AIzaSy...your_gemini_api_key_here

# Nodemailer Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
